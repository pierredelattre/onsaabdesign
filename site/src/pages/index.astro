<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>onsaabdesign.com</title>
    <meta
      name="description"
      content="An independent archive on Saab automotive design. Ergonomics, engineering, design, philosophy, people."
    />
    <meta property="og:title" content="onsaabdesign" />
    <meta
      property="og:description"
      content="An independent archive on Saab automotive design."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <div class="dot"></div>
      <div class="head">
        <p class="brand">onsaabdesign.com</p>
        <p>An independent archive on Saab automotive design.</p>
      </div>
      <p class="secondary">
        Documenting the design, ergonomics and engineering philosophy behind a
        marque that got it right.
      </p>
      <div class="tags">
        <p class="tag">Ergonomics</p>
        <p class="tag">Design</p>
        <p class="tag">Engineering</p>
        <p class="tag">Philosophy</p>
        <p class="tag">People</p>
      </div>
      <p class="contact">
        <a href="mailto:contact@onsaabdesign.com">contact@onsaabdesign.com</a> — 2026
      </p>
    </main>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    height: 100%;
  }

  body {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #faf8f4;
    color: #000;
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.9rem;
    min-height: 100vh;
    padding: 2rem;
  }

  main {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 520px;
    width: 100%;
  }

  .dot {
    position: absolute;
    top: -40px;
    height: 16px;
    width: 16px;
    background-color: #000;
    border-radius: 999px;
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .brand {
    font-weight: 500;
    color: #000;
  }

  .primary {
    font-weight: 500;
    line-height: 1.5;
    color: #000;
  }

  .secondary {
    font-weight: 400;
    line-height: 1.5;
    color: #636363;
  }

  .tags {
    display: flex;
    flex-direction: row;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .tags .tag {
    font-weight: 400;
    font-size: 0.875rem;
    white-space: nowrap;
    color: #696767;
    border: 1px solid #bfbfbf;
    border-radius: 999px;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
  }

  .contact {
    font-weight: 500;
    font-size: 0.875rem;
    color: #000;
  }

  .contact a {
    color: #000;
    text-decoration: none;
    border-bottom: 1px solid #000;
    padding-bottom: 1px;
    transition: opacity 0.15s ease;
  }

  .contact a:hover {
    opacity: 0.6;
  }

  @media (max-width: 1024px) {
    main {
      max-width: 100%;
      margin: 2rem;
    }
  }

  @media (max-width: 768px) {
    main {
      max-width: 100%;
      margin: 1rem;
    }
  }
</style>
